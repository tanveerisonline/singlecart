generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id               String         @id @default(cuid())
  name             String?
  email            String         @unique
  password         String
  phone            String?        @unique
  image            String?
  role             String         @default("USER")
  emailVerified    DateTime?
  twoFactorEnabled Boolean        @default(false)
  resetToken       String?
  resetTokenExpiry DateTime?
  referralCode     String?        @unique @default(cuid())
  referredById     String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  activityLogs     ActivityLog[]
  addresses        Address[]
  cartItems        CartItem[]
  orders           Order[]
  reviews          Review[]
  wishlist         WishlistItem[]
  giftCards        GiftCard[]
  referredBy       User?          @relation("UserReferrals", fields: [referredById], references: [id])
  referrals        User[]         @relation("UserReferrals")
}

model Address {
  id         String   @id @default(cuid())
  userId     String
  label      String
  street     String
  city       String
  state      String
  postalCode String
  country    String
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders     Order[]  @relation("ShippingAddress")
}

model Category {
  id              String     @id @default(cuid())
  name            String     @unique
  slug            String     @unique
  description     String?
  imageUrl        String?
  iconUrl         String?
  metaTitle       String?
  metaDescription String?
  metaImageUrl    String?
  isActive        Boolean    @default(true)
  parentId        String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  parent          Category?  @relation("SubCategories", fields: [parentId], references: [id])
  subCategories   Category[] @relation("SubCategories")
  products        Product[]
}

model Product {
  id                 String           @id @default(cuid())
  name               String
  slug               String           @unique
  description        String
  shortDescription   String?
  productType        String           @default("PHYSICAL")
  tax                Float            @default(0)
  price              Float
  compareAtPrice     Float?
  sku                String           @unique
  stock              Int              @default(0)
  lowStockThreshold  Int              @default(10)
  reservedUntil      DateTime?        // For temporary stock reservation during checkout
  categoryId         String
  brandId            String?
  specifications     String?
  isFeatured         Boolean          @default(false)
  isSafeCheckout     Boolean          @default(false)
  isSecureCheckout   Boolean          @default(false)
  isSocialShare      Boolean          @default(true)
  isEncourageOrder   Boolean          @default(false)
  isEncourageView    Boolean          @default(false)
  isTrending         Boolean          @default(false)
  isActive           Boolean          @default(true)
  thumbnailUrl       String?
  sizeChartUrl       String?
  hasWatermark       Boolean          @default(false)
  stockStatus        String           @default("in_stock")
  discount           Float            @default(0)
  salePrice          Float            @default(0)
  saleStartDate      DateTime?
  saleEndDate        DateTime?
  unit               String?
  wholesalePriceType String?
  isRandomRelated    Boolean          @default(false)
  crossSellIds       String?          // Comma-separated IDs or JSON string
  videoUrl           String?
  metaTitle          String?
  metaDescription    String?
  metaImageUrl       String?
  weight             Float?           // Now treated as Gms in UI
  isFreeShipping     Boolean          @default(false)
  estimatedDeliveryText String?
  isReturnable       Boolean          @default(true)
  returnPolicyText   String?
  showDimensions     Boolean          @default(false)
  length             Float?
  width              Float?
  height             Float?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  cartItems          CartItem[]
  orderItems         OrderItem[]
  brand              Brand?           @relation(fields: [brandId], references: [id])
  category           Category         @relation(fields: [categoryId], references: [id])
  images             ProductImage[]
  variants           ProductVariant[]
  reviews            Review[]
  stockLogs          StockLog[]
  wishlist           WishlistItem[]
  tags               Tag[]            @relation("ProductTags")
  bundles            Bundle[]         @relation("ProductBundles")
}

model Tag {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[] @relation("ProductTags")
}

model Brand {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  logoUrl   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
}

model ProductImage {
  id        String  @id @default(cuid())
  url       String
  alt       String?
  order     Int     @default(0)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductVariant {
  id        String     @id @default(cuid())
  productId String
  name      String
  sku       String     @unique
  price     Float?
  stock     Int        @default(0)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  product   Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  stockLogs StockLog[]
}

model Media {
  id        String   @id @default(cuid())
  name      String
  url       String
  type      String
  size      Int
  width     Int?
  height    Int?
  createdAt DateTime @default(now())
}

model Attribute {
  id        String           @id @default(cuid())
  name      String           @unique
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  values    AttributeValue[]
}

model AttributeValue {
  id          String    @id @default(cuid())
  value       String
  attributeId String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  attribute   Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@unique([attributeId, value])
}

model StockLog {
  id            String          @id @default(cuid())
  productId     String
  variantId     String?
  change        Int
  reason        String?
  previousStock Int
  newStock      Int
  createdAt     DateTime        @default(now())
  variant       ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)
  product       Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Order {
  id                String      @id @default(cuid())
  orderNumber       String      @unique
  userId            String
  status            String      @default("PENDING")
  totalAmount       Float
  shippingAddressId String
  paymentStatus     String      @default("PENDING")
  paymentMethod     String?
  shippingMethod    String?
  shippingCost      Float       @default(0)
  trackingNumber    String?
  couponId          String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  coupon            Coupon?     @relation(fields: [couponId], references: [id])
  shippingAddress   Address     @relation("ShippingAddress", fields: [shippingAddressId], references: [id])
  user              User        @relation(fields: [userId], references: [id])
  items             OrderItem[]
  payments           Payment[]
  returnRequest      ReturnRequest?
  }

model ReturnRequest {
  id          String   @id @default(cuid())
  orderId     String   @unique
  reason      String
  description String?
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED, COMPLETED
  adminNotes  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  order       Order    @relation(fields: [orderId], references: [id])
}

model FAQ {
  id        String   @id @default(cuid())
  question  String
  answer    String
  category  String   @default("General")
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GiftCard {
  id            String   @id @default(cuid())
  code          String   @unique
  balance       Float
  initialAmount Float
  isActive      Boolean  @default(true)
  expiryDate    DateTime?
  userId        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User?    @relation(fields: [userId], references: [id])
}

model Bundle {
  id          String    @id @default(cuid())
  name        String
  description String?
  price       Float
  isActive    Boolean   @default(true)
  image       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[] @relation("ProductBundles")
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Float
  product   Product @relation(fields: [productId], references: [id])
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Review {
  id         String   @id @default(cuid())
  rating     Int
  title      String?
  comment    String?
  isApproved Boolean  @default(false)
  userId     String
  productId  String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id])
  images     ReviewImage[]
}

model ReviewImage {
  id        String @id @default(cuid())
  reviewId  String
  url       String
  review    Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  ipAddress String?
  device    String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Payment {
  id            String   @id @default(cuid())
  orderId       String
  transactionId String   @unique
  amount        Float
  status        String
  method        String
  createdAt     DateTime @default(now())
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Coupon {
  id            String   @id @default(cuid())
  code          String   @unique
  discountType  String
  discountValue Float
  minPurchase   Float    @default(0)
  maxDiscount   Float?
  startDate     DateTime
  endDate       DateTime
  usageLimit    Int?
  usageCount    Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  orders        Order[]
}

model Page {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  content   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StoreSetting {
  id                    String   @id @default("default")
  storeName             String   @default("Shop")
  storeEmail            String   @default("contact@shop.com")
  storePhone            String?
  currency              String   @default("USD")
  address               String?
  taxRate               Float    @default(0)
  shippingFee           Float    @default(5.00)
  freeShippingThreshold Float    @default(100.00)
  homeLayout            String   @default("default")
  hotjarId              String?
  clarityId             String?
  updatedAt             DateTime @updatedAt
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model ThemeSetting {
  id                 String   @id @default("default")
  logoUrl            String?
  logoWidth          Int      @default(128)
  logoHeight         Int      @default(40)
  faviconUrl         String?
  primaryColor       String   @default("#4f46e5")
  safeCheckoutImage  String?
  secureCheckoutImage String?
  contactEmail       String?
  contactPhone       String?
  address            String?
  facebookUrl        String?
  instagramUrl       String?
  twitterUrl         String?
  updatedAt          DateTime @updatedAt
}

model SliderImage {
  id        String   @id @default(cuid())
  title     String?
  link      String?
  imageUrl  String
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DynamicSection {
  id          String   @id @default(cuid())
  name        String   // Internal name for identification
  page        String   @default("HOME") // e.g., HOME, CATEGORY, PRODUCT
  location    String   @default("MIDDLE") // e.g., TOP, MIDDLE, BOTTOM
  layout      String   @default("FULL_WIDTH") // FULL_WIDTH, TWO_COLUMNS, THREE_COLUMNS, ROW
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  containerClassName String? // Optional Tailwind classes for the section container
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  banners     Banner[]
}

model Banner {
  id               String         @id @default(cuid())
  sectionId        String
  title            String?
  subtitle         String?
  description      String?
  buttonText       String?
  buttonLink       String?
  discountText     String?        // e.g., "Up to 50% Off"
  bgColor          String?        @default("#ffffff")
  textColor        String?        @default("#000000")
  imageUrl         String?
  order            Int            @default(0)
  isActive         Boolean        @default(true)
  className        String?        // Optional Tailwind classes for individual banner
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  section          DynamicSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
}

model FilterSetting {
  id               String   @id @default("default")
  showCategory     Boolean  @default(true)
  showBrand        Boolean  @default(true)
  showPrice        Boolean  @default(true)
  showRating       Boolean  @default(true)
  showAvailability Boolean  @default(true)
  showDiscount     Boolean  @default(true)
  updatedAt        DateTime @updatedAt
}

model PaymentSetting {
  id                   String   @id @default("default")
  
  stripeIsEnabled      Boolean  @default(false)
  stripeSecretKey      String?
  stripePublishableKey String?
  
  paypalIsEnabled      Boolean  @default(false)
  paypalClientId       String?
  paypalSecretKey      String?
  paypalMode           String   @default("sandbox") // sandbox or live
  
  razorpayIsEnabled    Boolean  @default(false)
  razorpayKeyId        String?
  razorpayKeySecret    String?
  
  codIsEnabled         Boolean  @default(true)
  
  updatedAt            DateTime @updatedAt
}
